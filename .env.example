# Storage Configuration
# Choose adapter type: memory, libsql, or server
VITE_STORAGE=memory

# TursoDB / LibSQL Configuration (required for VITE_STORAGE=libsql)
# Create a database at https://turso.tech
VITE_TURSO_URL=libsql://your-database.turso.io
VITE_TURSO_AUTH_TOKEN=your-auth-token-here

# Server API Configuration (required for VITE_STORAGE=server)
VITE_API_BASE_URL=http://localhost:3000/api

# Test Configuration
# Set to 1 to run libSQL integration tests (requires VITE_TURSO_URL and VITE_TURSO_AUTH_TOKEN)
RUN_DB_TESTS=0

# LLM Generator Configuration (M3+)
# Controls candidate generation mode in L1 Seed and L2 Promise stages
# 0 = fixture mode (returns pre-seeded candidates from test database, no API calls)
# 1 = live mode (calls real Anthropic/OpenAI API, requires valid API key below)
VITE_LLM_LIVE=0

# LLM API Keys (only required if VITE_LLM_LIVE=1)
# Anthropic Claude API key (get from: https://console.anthropic.com/settings/keys)
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...your-key-here...

# OpenAI API key (get from: https://platform.openai.com/api-keys)
VITE_OPENAI_API_KEY=sk-proj-...your-key-here...